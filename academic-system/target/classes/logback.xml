<?xml version="1.0" encoding="UTF-8"?>
<!--
    Configuração do Logback para o Academic System (TUS-2390).
    Registra logs no console e em arquivo, com timestamp, nível, classe e mensagem (AC-3).
    A configuração de logging é separada da lógica de negócio (AC-4).
-->
<configuration>

    <!-- Appender para o console -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Appender para arquivo rotativo -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/academic-system.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Rotação diária; mantém 30 dias de histórico -->
            <fileNamePattern>logs/academic-system.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger raiz: INFO para console e FILE -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- Logger específico de segurança: nível DEBUG para capturar mais detalhes de auditoria -->
    <logger name="org.example.academic.system.security" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

</configuration>
